{
  "manifest_version": 3,
  "name": "Selector",
  "version": "1.0.0",
  "description": "Visual element picker — point at any element, tell your AI what to change.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Toggle Selector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": ["editor.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
